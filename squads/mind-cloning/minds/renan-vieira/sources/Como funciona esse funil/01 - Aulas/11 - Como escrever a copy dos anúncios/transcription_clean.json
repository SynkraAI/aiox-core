    },
    {
      "start": 410.18,
      "end": 415.18,
      "start_formatted": "06:50",
      "end_formatted": "06:55",
      "text": "Você pode fazer uma pergunta. Está travada as vendas da sua mentoria?",
      "type": "speech"
    },
    {
      "start": 415.18,
      "end": 419.18,
      "start_formatted": "06:55",
      "end_formatted": "06:59",
      "text": "Está com problema no seu casamento? Eu tenho a solução.",
