    },
    {
      "start": 352.18,
      "end": 355.18,
      "start_formatted": "05:52",
      "end_formatted": "05:55",
      "text": "Seja claro, quando eu começo a minha cópia aqui, ó.",
      "type": "speech"
    },
    {
      "start": 355.18,
      "end": 356.18,
      "start_formatted": "05:55",
      "end_formatted": "05:56",
