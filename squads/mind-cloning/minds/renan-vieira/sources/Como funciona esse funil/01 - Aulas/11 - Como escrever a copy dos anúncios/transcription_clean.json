    },
    {
      "start": 423.18,
      "end": 424.18,
      "start_formatted": "07:03",
      "end_formatted": "07:04",
      "text": "Entendeu?",
      "type": "speech"
    },
    {
      "start": 424.18,
      "end": 428.18,
      "start_formatted": "07:04",
      "end_formatted": "07:08",
