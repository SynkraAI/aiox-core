    },
    {
      "start": 473.36,
      "end": 476.12,
      "start_formatted": "07:53",
      "end_formatted": "07:56",
      "text": "Quantas pessoas hoje vivem com problema no casamento?",
      "type": "speech"
    },
    {
      "start": 476.12,
      "end": 478.56,
      "start_formatted": "07:56",
      "end_formatted": "07:58",
      "text": "Muitas problemas, né? Muitas pessoas.",
