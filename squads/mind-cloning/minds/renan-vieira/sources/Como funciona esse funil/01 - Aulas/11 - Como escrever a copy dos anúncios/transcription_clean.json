    },
    {
      "start": 480.56,
      "end": 485.42,
      "start_formatted": "08:00",
      "end_formatted": "08:05",
      "text": "Renan, como que eu vou atingir um público que tem problema no casamento e é bem financeiramente?",
      "type": "speech"
    },
    {
      "start": 485.42,
      "end": 488.48,
      "start_formatted": "08:05",
      "end_formatted": "08:08",
      "text": "Cara, eu vou falar com o médico?",
      "type": "speech"
    },
    {
      "start": 488.48,
      "end": 492.3,
      "start_formatted": "08:08",
      "end_formatted": "08:12",
      "text": "Se eu vou falar com o médico, o médico ganha 20, 50, 100, mil reais.",
      "type": "speech"
    },
    {
      "start": 492.3,
      "end": 493.3,
      "start_formatted": "08:12",
      "end_formatted": "08:13",
      "text": "O que que eu vou falar pra ele?",
      "type": "speech"
    },
    {
      "start": 493.3,
      "end": 495.74,
      "start_formatted": "08:13",
      "end_formatted": "08:15",
      "text": "Cara, médico, tá com problema no seu casamento?",
      "type": "speech"
    },
    {
      "start": 495.74,
      "end": 498.24,
      "start_formatted": "08:15",
      "end_formatted": "08:18",
      "text": "Cara, eu te mostro. Ou você...",
      "type": "speech"
    },
    {
      "start": 498.24,
      "end": 500.16,
      "start_formatted": "08:18",
      "end_formatted": "08:20",
      "text": "Eu preparei um vídeo como salvar o seu casamento.",
