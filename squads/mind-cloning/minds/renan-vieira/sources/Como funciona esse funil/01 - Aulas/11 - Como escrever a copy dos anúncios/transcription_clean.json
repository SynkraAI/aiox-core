    },
    {
      "start": 446.18,
      "end": 449.18,
      "start_formatted": "07:26",
      "end_formatted": "07:29",
      "text": "Inimigo. O que que é o inimigo? Cara, o site...",
      "type": "speech"
    },
    {
      "start": 449.18,
      "end": 450.18,
      "start_formatted": "07:29",
      "end_formatted": "07:30",
      "text": "Então, assim, eu peguei alguns exemplos aqui, tá?",
      "type": "speech"
    },
    {
      "start": 450.18,
      "end": 452.18,
      "start_formatted": "07:30",
      "end_formatted": "07:32",
      "text": "Instruções. O que que é as instruções?",
      "type": "speech"
    },
    {
      "start": 452.18,
      "end": 453.18,
      "start_formatted": "07:32",
      "end_formatted": "07:33",
      "text": "Pra você fazer em vídeo, eu fiz um mapa aqui, ó.",
