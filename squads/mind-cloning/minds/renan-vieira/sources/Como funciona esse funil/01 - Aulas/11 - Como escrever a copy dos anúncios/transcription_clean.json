    },
    {
      "start": 453.18,
      "end": 455.18,
      "start_formatted": "07:33",
      "end_formatted": "07:35",
      "text": "Que vai estar aqui debaixo. Que mapa é esse?",
      "type": "speech"
    },
    {
      "start": 455.18,
      "end": 457.18,
      "start_formatted": "07:35",
      "end_formatted": "07:37",
      "text": "Ai, Renan, eu quero gravar um vídeo. Então, ó.",
