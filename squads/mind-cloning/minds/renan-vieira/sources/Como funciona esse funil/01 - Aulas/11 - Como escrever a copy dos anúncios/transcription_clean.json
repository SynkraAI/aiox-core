    },
    {
      "start": 361.18,
      "end": 365.18,
      "start_formatted": "06:01",
      "end_formatted": "06:05",
      "text": "Plano que eu utilizo para vender de 10 a 30 mentorias de 3 mil reais todos os meses.",
