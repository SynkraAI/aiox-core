    },
    {
      "start": 676.44,
      "end": 682.62,
      "start_formatted": "11:16",
      "end_formatted": "11:22",
      "text": "Eu vendi 23 mentorias de R$3.000 e mais duas individuais de R$12.000",
      "type": "speech"
    },
    {
      "start": 682.62,
      "end": 687.98,
      "start_formatted": "11:22",
      "end_formatted": "11:27",
      "text": "nos últimos 30 dias, fiz R$90.000. Tá bom, né? R$90.000 tá bom.",
      "type": "speech"
    },
    {
      "start": 688.2800000000001,
      "end": 690.7600000000001,
      "start_formatted": "11:28",
      "end_formatted": "11:30",
      "text": "Então é isso que você pode fazer. Fechou? Então vai lá.",
