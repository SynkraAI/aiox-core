    },
    {
      "start": 460.18,
      "end": 462.18,
      "start_formatted": "07:40",
      "end_formatted": "07:42",
      "text": "Por exemplo, se eu vou ensinar aqui, ó. Se eu vou ensinar aqui, ó.",
