    },
    {
      "start": 691.1800000000001,
      "end": 692.7,
      "start_formatted": "11:31",
      "end_formatted": "11:32",
      "text": "Pode deixar suas perguntas aqui.",
      "type": "speech"
    },
    {
      "start": 693.0200000000001,
      "end": 696.1800000000001,
      "start_formatted": "11:33",
      "end_formatted": "11:36",
      "text": "Se você está dentro da mentoria, lá no grupo do WhatsApp, pode perguntar.",
