    },
    {
      "start": 400.18,
      "end": 403.18,
      "start_formatted": "06:40",
      "end_formatted": "06:43",
      "text": "Ai, Renan, eu quero fazer um vídeo em...",
      "type": "speech"
    },
    {
      "start": 403.18,
      "end": 407.18,
      "start_formatted": "06:43",
      "end_formatted": "06:47",
      "text": "Eu quero fazer um vídeo. Legal. Ó. Aqui eu botei vários ganchos.",
