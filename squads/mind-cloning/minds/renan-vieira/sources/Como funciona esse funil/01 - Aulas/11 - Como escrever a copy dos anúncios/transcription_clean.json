    },
    {
      "start": 580.62,
      "end": 585.0799999999999,
      "start_formatted": "09:40",
      "end_formatted": "09:45",
      "text": "Pra você ter exemplos de anúncios em vídeos que eu gravei.",
      "type": "speech"
    },
    {
      "start": 585.0799999999999,
      "end": 587.28,
      "start_formatted": "09:45",
      "end_formatted": "09:47",
      "text": "Eu não tô utilizando pra esse funil em vídeo.",
      "type": "speech"
    },
    {
      "start": 587.28,
      "end": 589.16,
      "start_formatted": "09:47",
      "end_formatted": "09:49",
      "text": "Só tô utilizando imagem. Renan, por quê?",
      "type": "speech"
    },
    {
      "start": 589.16,
      "end": 590.16,
      "start_formatted": "09:49",
      "end_formatted": "09:50",
      "text": "Porque eu não tive tempo.",
      "type": "speech"
    },
    {
      "start": 590.16,
      "end": 594.2199999999999,
      "start_formatted": "09:50",
      "end_formatted": "09:54",
      "text": "Tô dando aula, tô gravando os cursos e tudo.",
      "type": "speech"
    },
    {
      "start": 594.2199999999999,
      "end": 595.66,
      "start_formatted": "09:54",
      "end_formatted": "09:55",
      "text": "Então eu tô deixando isso meio de lado.",
      "type": "speech"
    },
    {
      "start": 595.66,
      "end": 598.1999999999999,
      "start_formatted": "09:55",
      "end_formatted": "09:58",
      "text": "Tô procurando focar mais nas vendas e deu.",
      "type": "speech"
    },
    {
      "start": 598.1999999999999,
      "end": 601.66,
      "start_formatted": "09:58",
      "end_formatted": "10:01",
      "text": "E montar o meu time comercial. Então aqui tem vários exemplos.",
      "type": "speech"
    },
    {
      "start": 601.66,
      "end": 604.16,
      "start_formatted": "10:01",
      "end_formatted": "10:04",
      "text": "Selecionei o público. Você é casada financeiramente?",
      "type": "speech"
    },
    {
      "start": 604.16,
      "end": 605.16,
      "start_formatted": "10:04",
      "end_formatted": "10:05",
      "text": "Bem sucedida?",
      "type": "speech"
    },
    {
      "start": 605.16,
      "end": 607.7199999999999,
      "start_formatted": "10:05",
      "end_formatted": "10:07",
      "text": "No final você sempre tem que colocar o CTA.",
      "type": "speech"
    },
    {
      "start": 607.7199999999999,
      "end": 610.48,
      "start_formatted": "10:07",
      "end_formatted": "10:10",
      "text": "Renan, o que que é o CTA?",
      "type": "speech"
    },
    {
      "start": 610.48,
      "end": 614.5799999999999,
      "start_formatted": "10:10",
      "end_formatted": "10:14",
      "text": "Aperte no botão aqui para assistir um vídeo de 10 minutos que eu te mostro como salvar",
      "type": "speech"
    },
    {
      "start": 614.5799999999999,
      "end": 615.5799999999999,
      "start_formatted": "10:14",
      "end_formatted": "10:15",
      "text": "o seu casamento.",
      "type": "speech"
    },
    {
      "start": 615.5799999999999,
      "end": 617.16,
      "start_formatted": "10:15",
      "end_formatted": "10:17",
      "text": "Aperte no botão aqui que eu te mostro como você pode vender de 10 a 30 mentoria.",
      "type": "speech"
    },
    {
      "start": 617.16,
      "end": 618.16,
      "start_formatted": "10:17",
      "end_formatted": "10:18",
      "text": "Então, eu vou te mostrar como você pode vender de 10 a 30 mentoria.",
      "type": "speech"
    },
    {
      "start": 618.16,
      "end": 619.16,
      "start_formatted": "10:18",
      "end_formatted": "10:19",
      "text": "Então, eu vou te mostrar como você pode vender de 10 a 30 mentoria.",
      "type": "speech"
    },
    {
      "start": 619.16,
      "end": 620.16,
      "start_formatted": "10:19",
      "end_formatted": "10:20",
      "text": "Cada aurípio.",
