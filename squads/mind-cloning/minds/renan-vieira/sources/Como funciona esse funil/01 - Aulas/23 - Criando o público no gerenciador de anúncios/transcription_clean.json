    },
    {
      "start": 47.22,
      "end": 48.56,
      "start_formatted": "00:47",
      "end_formatted": "00:48",
      "text": "Porque você precisa deixar.",
      "type": "speech"
    },
    {
      "start": 48.88,
      "end": 53.66,
      "start_formatted": "00:48",
      "end_formatted": "00:53",
      "text": "Se as pessoas vão chegar no seu Instagram e você precisa estar com o Instagram preparado.",
      "type": "speech"
    },
    {
      "start": 54.06,
      "end": 57.3,
      "start_formatted": "00:54",
      "end_formatted": "00:57",
      "text": "Então, vamos aqui para o que interessa. Eu vou vir aqui em gerenciar.",
