  "segments": [
    {
      "start": 0.26,
      "end": 6.7,
      "start_formatted": "00:00",
      "end_formatted": "00:06",
      "text": "Chegou a hora de a gente criar os públicos para nós fazer a campanha de anúncios no Instagram e no Facebook.",
      "type": "speech"
    },
    {
      "start": 7.0600000000000005,
      "end": 9.58,
      "start_formatted": "00:07",
      "end_formatted": "00:09",
      "text": "E a gente vai criar público quente só, Renan.",
      "type": "speech"
    },
    {
      "start": 9.66,
      "end": 10.94,
      "start_formatted": "00:09",
      "end_formatted": "00:10",
      "text": "Renan, o que é um público quente?",
      "type": "speech"
    },
    {
      "start": 11.08,
      "end": 15.92,
      "start_formatted": "00:11",
      "end_formatted": "00:15",
      "text": "Público quente é todo mundo que já se envolveu com você, de alguma forma.",
      "type": "speech"
    },
    {
      "start": 16.32,
      "end": 21.68,
      "start_formatted": "00:16",
      "end_formatted": "00:21",
      "text": "No site, no Instagram, Facebook, tudo. É isso que você vai fazer.",
      "type": "speech"
    },
    {
      "start": 21.86,
      "end": 24.02,
      "start_formatted": "00:21",
      "end_formatted": "00:24",
      "text": "Então, a gente vai criar o público quente.",
      "type": "speech"
    },
    {
      "start": 24.18,
      "end": 26.0,
      "start_formatted": "00:24",
      "end_formatted": "00:26",
      "text": "Se tiver lista de e-mail, nós vamos criar.",
      "type": "speech"
    },
    {
      "start": 26.400000000000002,
      "end": 27.48,
      "start_formatted": "00:26",
      "end_formatted": "00:27",
      "text": "Por que isso é importante?",
      "type": "speech"
    },
    {
      "start": 27.48,
      "end": 32.16,
      "start_formatted": "00:27",
      "end_formatted": "00:32",
      "text": "Isso é importante que essas pessoas são as primeiras pessoas que vão comprar de você.",
      "type": "speech"
    },
    {
      "start": 32.3,
      "end": 34.120000000000005,
      "start_formatted": "00:32",
      "end_formatted": "00:34",
      "text": "São as pessoas mais fáceis.",
      "type": "speech"
    },
    {
      "start": 34.38,
      "end": 36.36,
      "start_formatted": "00:34",
      "end_formatted": "00:36",
      "text": "Renan, mas eu tenho pouco público quente.",
      "type": "speech"
    },
    {
      "start": 36.5,
      "end": 37.32,
      "start_formatted": "00:36",
      "end_formatted": "00:37",
      "text": "Não se preocupa.",
      "type": "speech"
    },
    {
      "start": 37.68,
      "end": 41.42,
      "start_formatted": "00:37",
      "end_formatted": "00:41",
      "text": "Eu vou te ensinar a esquentar esse público frio em público quente.",
      "type": "speech"
    },
    {
      "start": 41.52,
      "end": 46.58,
      "start_formatted": "00:41",
      "end_formatted": "00:46",
      "text": "O que você precisa fazer é ajustar o teu Instagram que eu ensinei no módulo anterior.",
