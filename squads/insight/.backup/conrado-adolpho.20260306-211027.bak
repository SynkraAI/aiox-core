      - id: "CA007"
        name: "Regra Escada Produtos"
        rule: "SE oferecendo 1 produto → ticket = X. SE 6 passos → ticket = 3-4X"
        application: "Sempre desenhar: add-on → upgrade → bundle → continuidade → novo → mentor"

      - id: "CA008"
        name: "Regra Overdelivery"
        rule: "SE entregando exatamente combinado → cliente satisfeito (NPS 6-7). SE 30% extra → fã (NPS 9-10)"
        application: "Bônus automático: acesso, suporte, vídeo onboarding"

  veto:
    - trigger: "CAC > 20% TM"
      action: "STOP - Modelo quebrado, não escala"
    - trigger: "4 Metas fora de ordem"
      action: "STOP - Empresa vai quebrar, sequência obrigatória"
    - trigger: "9 Públicos não identificados"
