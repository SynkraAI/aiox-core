# =============================================================================
# Tocks Tracking - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Deploy target: Railway / any Node 20+ runtime. Stateless; all durable state
# lives in Supabase (same instance as @tocks/sales-ai).
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
PORT=3100
NODE_ENV=production
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Supabase (shared with tocks-sales-ai) - SECRET
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Google Ads Offline Conversion Upload - SECRET
# -----------------------------------------------------------------------------
# Credentials live in D:/jarvis/mcp-ads-bridge/.env (reuse the same 4 secrets).
# If any of the four is empty, uploader is DISABLED (no network calls).
# Testing-mode OAuth app token expires ~7 days after each reauth.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Google Ads - non-secret IDs
# -----------------------------------------------------------------------------
GOOGLE_ADS_LOGIN_CUSTOMER_ID=7943699417
GOOGLE_ADS_TOCKS_CUSTOMER_ID=8146675397
GOOGLE_ADS_CONVERSION_ACTION_LEAD_ID=7550396040
GOOGLE_ADS_CONVERSION_ACTION_PURCHASE_ID=7161904202
GOOGLE_ADS_API_VERSION=v20
GOOGLE_ADS_TIMEOUT_MS=10000
GOOGLE_ADS_TIMEZONE=America/Sao_Paulo
GOOGLE_ADS_DEFAULT_LEAD_VALUE=13000

# -----------------------------------------------------------------------------
# Tray webhook - SECRET
# -----------------------------------------------------------------------------
# FIX B1: REQUIRED in production - server fail-closes at boot if missing.
# Generate with `openssl rand -hex 32`. Share with Tray dev via Signal/WhatsApp
# (NEVER email). Used for HMAC-SHA256 X-Tray-Signature header OR fallback
# secret-in-URL (?k=<secret>) when Tray doesn't support HMAC natively.
TRAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# CORS allowlist (for /api/capture-gclid)
# -----------------------------------------------------------------------------
# FIX B2: REQUIRED in production - server fail-closes at boot if missing.
# Comma-separated list of origins allowed to POST gclid captures.
CORS_ORIGINS=https://tockscustom.com.br,https://www.tockscustom.com.br

# -----------------------------------------------------------------------------
# Rate limiting (optional - sane defaults)
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
